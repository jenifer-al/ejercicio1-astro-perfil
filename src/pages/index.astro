---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Jennifer's Portfolio">

  <div class="w-[1500px] max-w-full mx-auto px-4">

    <header class="bg-teal-300 w-full mb-5 rounded-xl py-6">

      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-center mt-3 mb-5 text-teal-950 font-bold">
        JENIFER GONZÁLEZ DÍAZ
      </h1>

      <h2 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl text-center mb-3 font-bold">
        Desarrollo Frontend
      </h2>

     

    </header>


    <main class="w-full mb-20">

      <figure>
        <img
          src="img/avatar.png"
          alt="Avatar de Jennifer"
          class="w-32 sm:w-40 md:w-48 lg:w-52
          border border-teal-600 rounded-3xl
          mx-auto mt-10 mb-4"
        />
      </figure>


      <h3 class="text-center text-teal-950 font-bold">
        Acerca de mí
      </h3>


      <p class="mt-10 max-w-3xl mx-auto px-4 text-center md:text-left">
        Lorem ipsum dolor sit, amet consectetur adipisicing elit. Soluta,
        reiciendis eveniet? Aliquid adipisci, officia quis ipsam corrupti
        eveniet accusantium molestias accusamus quos numquam minus molestiae
        deserunt, sit vero laudantium hic.
      </p>

      <!-- aquí sigue todo tu contenido del main -->

    </main>

  </div>

</Layout>